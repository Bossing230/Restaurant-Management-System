# ══════════════════════════════════════════════════════
# RestaurantOS v2 — Environment Variables
# ══════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Allowed origins — add your Flutter web port here
# Flutter web usually runs on port 49977 or similar
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:51508,http://localhost:49977,http://localhost:5000,http://127.0.0.1:49977,http://127.0.0.1:51508,http://10.0.2.2:3000

# ── PostgreSQL ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restaurant_os
DB_USER=postgres
DB_PASSWORD=JOSEPH12012005

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ────────────────────────────────────────────────
JWT_SECRET=restaurantos_jwt_secret_change_this_in_production_2025
JWT_REFRESH_SECRET=restaurantos_refresh_secret_change_this_in_production_2025
JWT_EXPIRES_IN=15m

# ── Docker Compose (uncomment if using docker-compose) ─
# DB_HOST=postgres
# REDIS_URL=redis://redis:6379